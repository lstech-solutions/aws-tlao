{
	email {$LETSENCRYPT_EMAIL}
	admin off
}

(_common_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		-Server
	}
}

{$MAIL_FQDN} {
	log {
		output file /var/log/caddy/access.log {
			roll_size 25MiB
			roll_keep 10
			roll_keep_for 336h
		}
		format json
	}

	import _common_headers

	reverse_proxy stalwart:8080
}

{$SNAPPYMAIL_HOSTS} {
	log {
		output file /var/log/caddy/access.log {
			roll_size 25MiB
			roll_keep 10
			roll_keep_for 336h
		}
		format json
	}

	import _common_headers

	reverse_proxy snappymail:8888
}

autoconfig.xn--tlo-fla.com, autodiscover.xn--tlo-fla.com {
	log {
		output file /var/log/caddy/access.log {
			roll_size 25MiB
			roll_keep 10
			roll_keep_for 336h
		}
		format json
	}

	import _common_headers

	root * /config/autoconfig

	@thunderbird path /mail/config-v1.1.xml
	handle @thunderbird {
		header Content-Type "application/xml; charset=utf-8"
		file_server
	}

	handle {
		respond "Not found" 404
	}
}
