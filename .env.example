# Generated by @edcalderon/versioning workspace-env. Do not edit directly.
# Canonical root env example

# Shared secret used to hash backend API keys.
API_KEY_HASH_SECRET=replace-with-long-random-secret
# Base path for the main application routes.
APP_BASE_PATH=/app
# Version label exposed by the landing app UI.
APP_VERSION=1.3.20
# AWS account id used by backend and infra tooling.
AWS_ACCOUNT_ID=058264267235
# Primary AWS region for TLAO services.
AWS_REGION=us-east-2
# API key used by the email package when calling the backend.
BACKEND_API_KEY=replace-with-backend-api-key
# Backend base URL used by the email package.
BACKEND_API_URL=http://localhost:3000
# Default Bedrock max tokens for backend requests.
BEDROCK_MAX_TOKENS=2000
# Default Bedrock model id for backend requests.
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
# Default Bedrock temperature for backend requests.
BEDROCK_TEMPERATURE=0.7
# CodeStar connection ARN used when creating infra pipelines.
CODESTAR_CONNECTION_ARN=arn:aws:codestar-connections:us-east-2:058264267235:connection/replace-me
# Base URL used by the docs site itself.
DOCS_BASE_URL=/
# Docs path exposed to the landing app for cross-app links.
DOCS_PUBLIC_BASE_PATH=/documentation
# Production site URL used by the docs app.
DOCS_SITE_URL=https://docs.tlao.com
# Backend DynamoDB table for documents.
DYNAMODB_DOCUMENTS_TABLE=tlao-documents
# Backend DynamoDB table for results.
DYNAMODB_RESULTS_TABLE=tlao-results
# Backend DynamoDB table for sessions.
DYNAMODB_SESSIONS_TABLE=tlao-sessions
# Backend DynamoDB table for users.
DYNAMODB_USERS_TABLE=tlao-users
# S3 bucket used by the email package.
EMAIL_BUCKET=tlao-email
# Backend free-tier daily request limit.
FREE_TIER_DAILY_LIMIT=1000
# Backend free-tier per-minute request limit.
FREE_TIER_RATE_LIMIT=100
# Backend free-tier storage cap in bytes.
FREE_TIER_STORAGE_CAP=5368709120
# Backend free-tier daily token limit.
FREE_TIER_TOKEN_LIMIT=100000
# GitHub repository slug used by infra pipeline config.
GITHUB_REPO=tlao-org/tlao
# Safety gate for creating or mutating CodePipeline resources.
INFRA_CREATE_PIPELINES=false
# Base path used by the landing app.
LANDING_BASE_PATH=
# Default backend log level.
LOG_LEVEL=info
# S3 bucket used by the backend package.
S3_BUCKET_NAME=tlao-documents
# Legacy Stalwart auth value. Use username:secret for Basic auth or a raw bearer token if required.
STALWART_API_KEY=tlao-provisioner:replace-with-stalwart-api-secret
# Stalwart management API secret used for mailbox provisioning.
STALWART_API_SECRET=replace-with-stalwart-api-secret
# Stalwart management API username or API key id used for mailbox provisioning.
STALWART_API_USERNAME=tlao-provisioner
# Base URL for the local or remote Stalwart server.
STALWART_URL=http://localhost:8080
